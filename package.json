{
  "name": "clothos-motor-api",
  "version": "0.1.0",
  "description": "Clothos Motor — pipeline de consultas Node.js/TypeScript",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --watch --import @swc-node/register/esm-register src/presentation/server.ts",
    "build": "swc src -d dist --copy-files && tsc-alias",
    "start": "node dist/presentation/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix .",
    "typecheck": "tsc --noEmit",
    "test:integration": "jest --config jest.integration.config.cjs --runInBand --forceExit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "dotenv": "^17.4.2",
    "hono": "^4.7.11",
    "pg": "^8.22.0",
    "pino": "^9.7.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@swc-node/register": "^1.10.10",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.12.7",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "jest": "^29.7.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.8.3"
  }
}
