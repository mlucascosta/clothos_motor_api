# O motor é um WORKER, não um servidor HTTP (ADR-0025).
# Ele fala com o Laravel exclusivamente pela fila em reduto_core.jobs — não expõe porta,
# não recebe requisição e não tem segredo compartilhado de API.
NODE_ENV=development
LOG_LEVEL=info

# Fila consumida por este worker: full | lite | monitor.
# O processador default é escolhido pela fila (Finder × Monitoramento).
WORKER_QUEUE=full

# Escavador — https://api.escavador.com
ESCAVADOR_API_KEY=
ESCAVADOR_BASE_URL=https://api.escavador.com

# DataJud (CNJ) — API Pública
# Chave pública padrão do CNJ (pode substituir por chave própria)
DATAJUD_APIKEY='APIKey cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw=='
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# DirectData — https://apiv3.directd.com.br
# Usar DIRECTDATA_TOKEN (preferido) ou DIRECTDATA_APIKEY como fallback
DIRECTDATA_TOKEN=
DIRECTDATA_APIKEY=

# ApiBrasil — https://apibrasil.com.br
# Obter em: https://apibrasil.com.br/painel
# Exige AS DUAS variáveis; faltando uma, a fonte apibrasil_cadastro_pj não é registrada.
APIBRASIL_API_KEY=
APIBRASIL_DEVICE_TOKEN=

# Infosimples — https://api.infosimples.com
# Obter em: https://infosimples.com/api-de-dados/
# ATENÇÃO: o nome é INFOSIMPLES_API_KEY. O antigo INFOSIMPLES_TOKEN (usado pela API HTTP
# legada, já removida) NÃO é lido pelo worker — quem seguia este arquivo ficava, em silêncio,
# sem as fontes infosimples_cnpj, infosimples_ceis e infosimples_cnep.
INFOSIMPLES_API_KEY=

# BrasilAPI — API pública, sem autenticação
# Sobrescrever apenas em ambientes de teste/staging
BRASILAPI_BASE_URL=https://brasilapi.com.br/api

# Database — PostgreSQL (single-store, ADR-0019)
# Motor acessa exclusivamente reduto_core (não é multi-tenant).
# Em dev local via Docker: postgres://clothos:clothos@localhost:5432/reduto_core
# Em produção: string de conexão PgBouncer apontando para reduto_core
DATABASE_URL=postgres://clothos:clothos@localhost:5432/reduto_core
# Alias aceito se DATABASE_URL não estiver definido
MOTOR_DATABASE_URL=
