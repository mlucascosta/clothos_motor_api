# Servidor
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Segurança interna — token exigido em todas as rotas /api/*
MOTOR_INTERNAL_SECRET=

# Escavador — https://api.escavador.com
ESCAVADOR_API_KEY=
ESCAVADOR_BASE_URL=https://api.escavador.com

# DataJud (CNJ) — API Pública
# Chave pública padrão do CNJ (pode substituir por chave própria)
DATAJUD_APIKEY='APIKey cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw=='
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# DirectData — https://apiv3.directd.com.br
# Usar DIRECTDATA_TOKEN (preferido) ou DIRECTDATA_APIKEY como fallback
DIRECTDATA_TOKEN=
DIRECTDATA_APIKEY=

# ApiBrasil — https://apibrasil.com.br
# Obter em: https://apibrasil.com.br/painel
APIBRASIL_API_KEY=
APIBRASIL_DEVICE_TOKEN=

# Infosimples — https://api.infosimples.com
# Autenticação via query param token (POST)
# Obter em: https://infosimples.com/api-de-dados/
INFOSIMPLES_TOKEN=

# BrasilAPI — API pública, sem autenticação
# Sobrescrever apenas em ambientes de teste/staging
BRASILAPI_BASE_URL=https://brasilapi.com.br/api

# Database — PostgreSQL (single-store, ADR-0019)
# Motor acessa exclusivamente clothos_core (não é multi-tenant).
# Em dev local via Docker: postgres://clothos:clothos@localhost:5432/clothos_core
# Em produção: string de conexão PgBouncer apontando para clothos_core
DATABASE_URL=postgres://clothos:clothos@localhost:5432/clothos_core
# Alias aceito se DATABASE_URL não estiver definido
MOTOR_DATABASE_URL=
